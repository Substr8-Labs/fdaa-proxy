# Substr8 MCP Server
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies first (for caching)
RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    click \
    rich \
    httpx \
    pydantic

# Copy source
COPY substr8/ ./substr8/

# Create non-root user
RUN useradd -m -u 1000 substr8
USER substr8

# Default port (Railway sets PORT env var at runtime)
ENV PORT=8080
EXPOSE 8080

# Health check disabled - Railway handles this
# HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
#     CMD curl -f http://localhost:${PORT}/health || exit 1

# Start server - PORT env var is set by Railway
CMD ["sh", "-c", "python -m substr8.mcp --host 0.0.0.0 --port $PORT"]
